{
  "expo": {
    "name": "Retweet",
    "slug": "retweet-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "retweet",
    "userInterfaceStyle": "light",
    "extra": {
      "apiUrl": "http://192.168.100.51:3000",
      "webAppUrl": "",
      "webDevPort": 3077,
      "router": {},
      "eas": {
        "projectId": "c729b1ff-0998-46dc-9649-0bc261332423"
      }
    },
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.retweetmobile.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "يُستخدم الميكروفون لتسجيل الرسائل الصوتية في المحادثات.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "permissions": [
        "RECORD_AUDIO"
      ],
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "owner": "tareqg123"
  }
}
