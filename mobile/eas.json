{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "local-sideload": {
      "distribution": "internal",
      "credentialsSource": "local",
      "ios": {
        "simulator": false,
        "buildConfiguration": "Release"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://wichita-php-welfare-instructional.trycloudflare.com",
        "EXPO_PUBLIC_WEB_APP_URL": "https://wichita-php-welfare-instructional.trycloudflare.com/app",
        "EXPO_PUBLIC_WEB_APP_URL_STRICT": "1"
      }
    },
    "sideload": {
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "buildConfiguration": "Release"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://wichita-php-welfare-instructional.trycloudflare.com",
        "EXPO_PUBLIC_WEB_APP_URL": "https://wichita-php-welfare-instructional.trycloudflare.com/app",
        "EXPO_PUBLIC_WEB_APP_URL_STRICT": "1"
      }
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "buildConfiguration": "Debug"
      }
    },
    "simulator": {
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "android-apk": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_WEB_APP_URL": "https://reyweet.vercel.app/app",
        "EXPO_PUBLIC_WEB_APP_URL_STRICT": "1",
        "EXPO_PUBLIC_API_URL": "https://islamic-broadband-urw-covered.trycloudflare.com"
      }
    }
  }
}
