# توكن Expo لبناء iOS عبر EAS (من https://expo.dev/settings/access-tokens)
# EXPO_TOKEN=

# عنوان تطبيق الويب داخل WebView (للتثبيت الأصلي على الآيفون)
# للإنترنت: شغّل npm run public:relaunch ثم npm run mobile:sync:public
# للشبكة المحلية: npm run mobile:sync
EXPO_PUBLIC_WEB_APP_URL=
EXPO_PUBLIC_WEB_APP_URL_STRICT=1

# Retweet API — يُحدَّث تلقائياً بـ npm run mobile:sync
EXPO_PUBLIC_API_URL=http://192.168.1.100:3000
