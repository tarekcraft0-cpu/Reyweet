# المنفذ ثابت في package.json (dev:lan → 3077) حتى يطابق EXPO_PUBLIC_WEB_APP_URL دائماً.
# مثال: EXPO_PUBLIC_WEB_APP_URL=http://192.168.1.50:3077
EXPO_PUBLIC_WEB_APP_URL=

# روابط تأكيد البريد واستعادة كلمة المرور من Supabase (يجب أن يُدرَج في Redirect URLs).
# إن لم تضبطه، يُستخدم EXPO_PUBLIC_WEB_APP_URL إن وُجد؛ وإلا يعتمد المشروع على Site URL في لوحة Supabase.
# EXPO_PUBLIC_SUPABASE_AUTH_REDIRECT_URL=http://localhost:8080

# عنوان Retweet API — استبدل 192.168.1.100 بعنوان IPv4 لجهازك (ويندوز: ipconfig → IPv4 Address)
# Supabase (نفس مشروع الويب)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# مفتاح anon JWT (يبدأ بـ eyJ) من لوحة Supabase → Settings → API — يُفضّل على مفتاح publishable القصير لتجنّب Invalid API key مع Auth
EXPO_PUBLIC_SUPABASE_JWT_ANON=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# أو المفتاح القابل للنشر:
# EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# خادم Retweet API (اختياري إذا لم تستخدم Supabase للمصادقة)
# EXPO_PUBLIC_API_URL=http://192.168.1.100:8788
