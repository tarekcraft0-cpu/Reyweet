# ——— Retweet API (محلي) ———
# PostgreSQL (Docker): المستخدم retweet / كلمة المرور retweet / DB retweet — انظر docker-compose.yml
# PostgreSQL مطلوب على المنفذ 5432. أسهل طريقة:
#   1) ثبّت Docker Desktop وشغّله
#   2) من جذر هذا المشروع: npm run db:up
#   3) ثم: npm run db:push
#   4) أعد تشغيل: npm run api:dev

DATABASE_URL="postgresql://retweet:retweet@localhost:5432/retweet"
PORT=8788
JWT_SECRET="dev-change-in-production-min-16-chars"
BCRYPT_ROUNDS=12

# معطّل: التطبيق يستخدم Supabase للمصادقة والمزامنة مباشرة (لا Retweet API محلي).
# VITE_API_URL=http://localhost:8788
# VITE_API_URL_MOBILE=http://localhost:8788

