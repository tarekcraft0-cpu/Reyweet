{
  "name": "tanstack_start_ts",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "start": "npm run start --prefix ./mobile",
    "dev": "vite dev",
    "dev:lan": "node scripts/dev-lan.mjs",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "mobile": "npm run start --prefix ./mobile",
    "mobile:sync": "node scripts/sync-mobile-ios.mjs",
    "mobile:sync:public": "node scripts/sync-mobile-ios.mjs --public",
    "mobile:sync:vercel": "node scripts/sync-mobile-ios.mjs --vercel",
    "mobile:ios:prebuild": "npm run prebuild:ios --prefix ./mobile",
    "mobile:ios:prepare": "powershell -ExecutionPolicy Bypass -File ./mobile/scripts/prepare-ios-windows.ps1",
    "mobile:iphone:now": "powershell -ExecutionPolicy Bypass -File ./mobile/scripts/install-iphone-now.ps1",
    "mobile:ios:install": "node scripts/sync-mobile-ios.mjs --public && npm run prebuild:ios --prefix ./mobile && npm run ios:device --prefix ./mobile",
    "mobile:eas:login": "npx eas-cli login",
    "mobile:eas:device": "npx eas-cli device:create --cwd mobile",
    "mobile:eas:build": "node scripts/eas-ios-build.mjs",
    "mobile:eas:build:go": "node scripts/eas-ios-build.mjs",
    "mobile:eas:retry": "node scripts/eas-ios-build.mjs",
    "mobile:ipa:sync": "node scripts/sync-mobile-ios.mjs --public",
    "mobile:ipa:build": "node scripts/build-ipa-sideload.mjs",
    "mobile:ipa:local": "node scripts/sync-mobile-ios.mjs --public && cd mobile && eas build --platform ios --profile local-sideload --local",
    "mobile:ipa:download": "npx eas-cli build:download --platform ios --latest --output ./mobile/dist-ipa/Retweet.ipa --cwd mobile",
    "mobile:ios:why-not-windows": "powershell -ExecutionPolicy Bypass -File ./mobile/scripts/windows-ios-limitation.ps1",
    "backend:dev": "npm run dev --prefix backend",
    "backend:start": "npm run start --prefix backend",
    "sync:api": "node scripts/sync-lan-api-url.mjs",
    "sync:public-api": "node scripts/write-public-web-config.mjs",
    "spa:dev:lan": "node scripts/sync-lan-api-url.mjs && npx vite dev --config vite.spa.config.ts --host 0.0.0.0 --port 3080",
    "tunnel:api": "powershell -ExecutionPolicy Bypass -File scripts/windows-expose-api.ps1",
    "local:stack": "node scripts/local-stack.mjs",
    "dev:all": "node scripts/dev-all.mjs",
    "stack:start": "powershell -ExecutionPolicy Bypass -File scripts/start-stack.ps1",
    "api:tunnel": "node scripts/launch-api-only.mjs",
    "vercel:build": "node scripts/build-for-vercel.mjs",
    "vercel:deploy": "node scripts/deploy-vercel-stack.mjs",
    "stack:reyweet": "node scripts/launch-api-only.mjs",
    "public:launch": "node scripts/launch-public.mjs",
    "public:relaunch": "node scripts/relaunch-public.mjs",
    "tunnel:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-stable-tunnel.ps1",
    "public:stable": "node scripts/launch-stable.mjs",
    "deploy:public": "node scripts/deploy-public.mjs",
    "deploy:public:full": "node scripts/deploy-public.mjs --full",
    "pwa:deploy": "npm run build:spa && node scripts/deploy-pwa-static.mjs",
    "api:dev": "npm run backend:dev",
    "icons:generate": "node scripts/generate-pwa-icons.mjs",
    "stickers:manifest": "node scripts/generate-custom-sticker-manifest.mjs",
    "build:spa": "node scripts/generate-pwa-icons.mjs && node scripts/generate-custom-sticker-manifest.mjs && vite build --config vite.spa.config.ts",
    "landing:build": "npm run build:spa && npm run build --prefix landing && node scripts/prepare-vercel-static.mjs",
    "landing:preview": "npm run landing:build && npx --yes serve _vercel_site -l tcp://0.0.0.0:4173",
    "landing:copy-builds": "node scripts/copy-app-builds.mjs",
    "mobile:apk:build": "node scripts/build-android-apk.mjs",
    "mobile:apk:deploy": "node scripts/deploy-android-release.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/core": "^7.4.3",
    "@capacitor/ios": "^7.4.3",
