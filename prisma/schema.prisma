// مخطط علائقي لـ Retweet — يكمّل التطبيق المحلي ويمكن توسيعه تدريجياً
// حقول JSON تحفظ هياكل مطابقة للعميل (هايلايت، ملصقات ستوري، إلخ) لتقليل تعقيد الجداول في المرحلة الأولى

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  username         String   @unique
  email            String   @unique
  /** معرف Google OAuth (sub) — اختياري */
  googleId         String?  @unique
  passwordHash     String
  bio              String   @default("")
  avatar           String   @default("")
  profileLink      String   @default("")
  isPrivate        Boolean  @default(false)
  verified         Boolean  @default(false)
  allowStoryReplies Boolean @default(true)
  showLikesAndFavoritesOnProfile Boolean @default(true)
  hideFollowListsFromOthers Boolean @default(false)
  displayFollowerCount Int?
  note             String?
  noteAt           BigInt?
  shareProfileVisitActivity Boolean @default(true)

  highlightsJson              Json @default("[]")
  followRequestInJson         Json @default("[]")
  followRequestOutJson        Json @default("[]")
  publicChannelIdsJson        Json @default("[]")
  favoriteStickerContentsJson Json @default("[]")
  createdStickerContentsJson  Json @default("[]")
  pinnedChatIdsJson           Json @default("[]")
  mutedChatIdsJson            Json @default("[]")
  profileViewsJson            Json @default("[]")

  appTheme    String @default("light")
  appLanguage String @default("ar")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts        Post[]
  stories      Story[]
  messages     Message[]      @relation("MessageSender")
  chatMembers  ChatMember[]
  stickers     Sticker[]
  mediaNotes   MediaNote[]

  notificationsReceived Notification[] @relation("NotifRecipient")
  notificationsSent   Notification[] @relation("NotifActor")

  blocksInitiated Block[] @relation("BlockerUser")
  blocksReceived  Block[] @relation("BlockedUser")

  closeFriendsOwned CloseFriend[] @relation("CloseFriendOwner")
  closeFriendsTag   CloseFriend[] @relation("CloseFriendMember")

  favoritePosts FavoritePost[]

  follows    Follow[] @relation("Follower")
  followedBy Follow[] @relation("Followee")

  /** نسخة كاملة من حالة التطبيق للمزامنة (تجاوز بناء الجداول العلائقية في الوقت الحالي) */
  appSnapshot UserAppSnapshot?
  passwordResetOtps OtpCode[]
}

/** لقطة JSON للعميل — تُحدَّث بعد كل تغيير عند تفعيل الخادم */
model UserAppSnapshot {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  state  Json
  updatedAt DateTime @updatedAt
}

/** رمز مؤقت لاستعادة كلمة المرور */
model OtpCode {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose   String
  codeHash  String
  expiresAt DateTime

  @@index([userId, purpose])
}

model Follow {
  followerId String
  followeeId String
  follower   User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followee   User @relation("Followee", fields: [followeeId], references: [id], onDelete: Cascade)

  @@id([followerId, followeeId])
  @@index([followeeId])
}

model Block {
  blockerId String
  blockedId String
  blocker   User @relation("BlockerUser", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User @relation("BlockedUser", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
}

model CloseFriend {
  ownerId  String
  friendId String
  owner    User @relation("CloseFriendOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  friend   User @relation("CloseFriendMember", fields: [friendId], references: [id], onDelete: Cascade)

  @@id([ownerId, friendId])
}

model FavoritePost {
  userId String
  postId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
}

model Post {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  text        String   @default("")
  image       String?
  video       String?
  likesJson   Json     @default("[]")
  repostsJson Json     @default("[]")
  createdAt   DateTime @default(now())

  comments  Comment[]
  favorites FavoritePost[]

  @@index([userId])
  @@index([createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  text      String
  createdAt DateTime @default(now())

  @@index([postId])
}

model Story {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  image        String
  video        String?
  audience     String   @default("all")
  stickersJson Json     @default("[]")
  likesJson    Json     @default("[]")
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Chat {
  id              String  @id @default(cuid())
  isGroup         Boolean @default(false)
  isChannel       Boolean @default(false)
  name            String?
  avatar          String?
  request         Boolean @default(false)
  theme           String?
  createdByUserId String?

  lastOpenAtByUserJson        Json @default("{}")
  lastReadMessageIdByUserJson Json @default("{}")
  hiddenMessageIdsByUserJson  Json @default("{}")
  pinnedMessageIdsJson        Json @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  ChatMember[]
  messages Message[]

  @@index([updatedAt])
}

model ChatMember {
  chatId  String
  userId  String
  isAdmin Boolean @default(false)
  isHost  Boolean @default(false)
  chat    Chat    @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([chatId, userId])
}

model Message {
  id         String   @id @default(cuid())
  chatId     String
  chat       Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId   String
  sender     User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  type       String
  content    String   @default("")
  createdAt  DateTime @default(now())
  extrasJson Json     @default("{}")

  @@index([chatId, createdAt])
}

model Notification {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation("NotifRecipient", fields: [userId], references: [id], onDelete: Cascade)
  fromId                String
  from                  User     @relation("NotifActor", fields: [fromId], references: [id], onDelete: Cascade)
  type                  String
  postId                String?
  storyId               String?
  chatId                String?
  text                  String?
  read                  Boolean  @default(false)
  followRequestStatus   String?
  createdAt             DateTime @default(now())

  @@index([userId, read])
}

model Sticker {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji  String
  label  String

  @@index([userId])
}

model MediaNote {
  id        String   @id @default(cuid())
  kind      String
  targetId  String
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  text      String
  createdAt DateTime @default(now())

  @@index([targetId])
}
