# مسار التخزين على القرص D (قاعدة البيانات + الميديا المضغوطة)
DATA_ROOT=D:/RetweetSocial

PORT=3000
HOST=0.0.0.0

JWT_SECRET=change_me_to_a_long_random_string_32chars
BCRYPT_ROUNDS=12

# PUBLIC_BASE_URL=https://your-tunnel.trycloudflare.com
# CORS_ORIGINS=https://reyweet.vercel.app

# ——— Gmail / OTP (إلزامي للتسجيل واستعادة كلمة المرور) ———
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=1
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password
# أو نفس القيم بأسماء بديلة:
# EMAIL_USER=your@gmail.com
# EMAIL_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM="Retweet <your@gmail.com>"

# لا تُظهر الرموز في استجابة API أو الواجهة (اتركه معطّلاً في الإنتاج)
# OTP_DEBUG=1

# حسابات أسماء قصيرة (اختياري — تُعرَّف أيضاً في shortUsernameAccounts.ts)
# SHORT_USERNAME_1_USER_ID=863b808b-0c26-4d9f-b1c5-b9b586e31d44
# SHORT_USERNAME_M_USER_ID=beb31b7a-1aa8-4268-b299-35aaf1d0de5f

# LOGIN_OTP_REQUIRED=1
# PUBLIC_APP_URL=https://reyweet.vercel.app

# ——— اشتراك التوثيق (Stripe — بطاقة + Apple Pay) ———
# من لوحة Stripe: Developers → API keys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# معرّف سعر اشتراك شهري (Products → Price) — اختياري لصفحة Checkout البديلة
# STRIPE_VERIFIED_PRICE_ID=price_...
