# ——— واجهة Vite (العميل) ———
# مزامنة Supabase الاختيارية (JSON blob لكل مستخدم) + تسجيل عبر Supabase عندما لا يُضبط VITE_API_URL
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
#
# مفتاح العميل لـ Auth + PostgREST: يفضّل مفتاح anon الـ JWT (يبدأ بـ eyJ) من Settings → API → anon public.
# إذا وضعت مفتاح publishable القصير (بادئة sb_) في ANON_KEY وظهرت رسالة Invalid API key، ضع الـ JWT في السطر التالي:
# VITE_SUPABASE_JWT_ANON=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# VITE_SUPABASE_ANON_KEY=
# أو المفتاح القابل للنشر (قد لا يكفي وحده لبعض عمليات Auth حسب إصدار المشروع):
# VITE_SUPABASE_PUBLISHABLE_KEY=

# اختياري: عنوان كامل لروابط تأكيد البريد من Supabase (يجب أن يُدرَج في Redirect URLs).
# إذا تركتَه فارغاً، يستخدم التطبيق تلقائياً origin المتصفح (بما فيه المنفذ، مثل http://localhost:8080).
# VITE_SUPABASE_AUTH_REDIRECT_URL=http://localhost:8080

# عناوين Retweet API — استبدل 192.168.1.100 بعنوان IPv4 لجهاز الكمبيوتر (ويندوز: ipconfig → IPv4)
# نفس العنوان للمتصفح ولـ Capacitor حتى يعمل الآيفون على نفس الـ Wi‑Fi (لا تستخدم localhost من الهاتف).
VITE_API_URL=http://192.168.1.100:8788
VITE_API_URL_MOBILE=http://192.168.1.100:8788

# ——— خادم API (Prisma + Hono) ———
# استماع على كل الواجهات (افتراضي في الكود: 0.0.0.0) حتى يصل الهاتف بالـ IP أعلاه
# HOST=0.0.0.0
# PostgreSQL عبر Docker (docker-compose.yml):
#   المستخدم: retweet
#   كلمة المرور: retweet
#   قاعدة البيانات: retweet
#   المنفذ على المضيف: 5432
DATABASE_URL="postgresql://retweet:retweet@localhost:5432/retweet"
PORT=8788
JWT_SECRET="غيّر_هذا_إلى_سلسلة_عشوائية_طويلة_في_الإنتاج"
BCRYPT_ROUNDS=12

# Google OAuth — نفس معرفات العميل التي في تطبيق Expo (EXPO_PUBLIC_GOOGLE_*)
# للتحقق من id_token على الخادم (يمكن وضع أكثر من قيمة عبر المتغيرات الثلاثة)
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
